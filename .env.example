# Shopify app credentials (from your Partner Dashboard app)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Comma-separated OAuth scopes (e.g. read_orders,write_checkouts)
SCOPES=

# App URL (e.g. https://your-app.vercel.app or ngrok URL for local dev)
SHOPIFY_APP_URL=

# Optional: set automatically on Vercel; used as fallback when SHOPIFY_APP_URL is not set
# VERCEL_URL=

# Optional: custom shop domain allowlist
# SHOP_CUSTOM_DOMAIN=

# Server ports (defaults: FRONTEND_PORT=8002, PORT=3000)
# FRONTEND_PORT=8002
# PORT=3000
